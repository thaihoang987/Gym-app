# Copy this file to .env for Docker Compose/local deployment overrides.

# Host port exposed by Docker Compose.
PORT=3001

# Default admin password used only when the database is created for the first time.
# Change this before first run on a public or shared network.
ADMIN_PASSWORD=change-me

# Timezone used by the container runtime.
TZ=America/New_York

# Runtime mode.
NODE_ENV=production
